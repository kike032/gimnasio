<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.1"
    xmlns="https://jakarta.ee/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd">

    <persistence-unit name="proyecto" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.ues.edu.modelo.Servicio</class>
        <class>com.ues.edu.modelo.Alumno</class>
        <class>com.ues.edu.modelo.Inscripcion</class>
        <class>com.ues.edu.modelo.Asistencia</class>
        <class>com.ues.edu.modelo.Atencion</class>
        <class>com.ues.edu.modelo.Comprobante</class>
        <class>com.ues.edu.modelo.Pago</class>
        <class>com.ues.edu.modelo.Rol</class>
        <class>com.ues.edu.modelo.Usuario</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/gimnasio"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="root"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>

</persistence>